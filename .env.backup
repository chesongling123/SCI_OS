# ============================================
# ResearchOS 环境变量模板
# 复制为 .env 后修改，.env 已加入 .gitignore
# ============================================

# 数据库
DATABASE_URL="postgresql://phd:phd_dev@localhost:5432/phd_os?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# 服务端口号
BACKEND_PORT=3000
FRONTEND_PORT=5173

# AI / LLM（LiteLLM Proxy）
LITELLM_API_URL="http://localhost:4000"
LITELLM_API_KEY="sk-kimi-FaXMfIAZCYGZ55g6r32OLwcH3F7Ryn72XA7q5ve6qVMCu3vFeam4X3MSnKIHxTkV"

# 本地 Ollama
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# 文件上传
UPLOAD_DIR="./uploads"

# AI / LLM 配置
AI_PROVIDER=kimi-coding
KIMI_CODING_API_KEY="sk-kimi-FaXMfIAZCYGZ55g6r32OLwcH3F7Ryn72XA7q5ve6qVMCu3vFeam4X3MSnKIHxTkV"
KIMI_CODING_BASE_URL=https://api.kimi.com/coding
KIMI_CODING_MODEL=k2p5

