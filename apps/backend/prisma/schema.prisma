// ============================================
// ResearchOS 数据库 Schema —— Phase 1（日程/任务/番茄钟）
// 本地优先架构：PostgreSQL（开发/云端）+ SQLite（本地生产）
// 所有表遵循：CUID 主键 · UTC 时间戳 · 软删除 · JSONB 可变结构
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ============================================
// 用户模块（Phase 1 最小实现，Phase 2 扩展 OAuth）
// ============================================
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String    // bcrypt 哈希
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // 关联
  events           Event[]
  tasks            Task[]
  pomodoroSessions PomodoroSession[]
  notes            Note[]
  noteFolders      NoteFolder[]
  references       Reference[]
  referenceFolders ReferenceFolder[]
  referenceNotes   ReferenceNote[]
  aiConversations  AiConversation[]
  settings         UserSettings?

  @@map("users")
}

// ============================================
// 用户设置模块
// ============================================
model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 外观设置
  theme             String   @default("system") // light / dark / system
  glassIntensity    Int      @default(100) // 0-200%
  fontSize          String   @default("medium") // small / medium / large
  sidebarCollapsed  Boolean  @default(false)

  // AI 设置（敏感字段如 apiKey 仅前端状态管理，不持久化到数据库）
  llmProvider       String   @default("kimi")
  llmModel          String   @default("k2p5")
  temperature       Float    @default(0.7)
  maxTokens         Int      @default(4096)
  systemPrompt      String?  @db.Text
  functionCalling   Boolean  @default(true)
  ragThreshold      Float    @default(0.7)
  ragTopK           Int      @default(5)
  streamingOutput   Boolean  @default(true)

  // 番茄钟设置
  pomodoroFocus      Int   @default(25) // 分钟
  pomodoroShortBreak Int   @default(5)
  pomodoroLongBreak  Int   @default(15)
  pomodoroAutoBreak  Boolean @default(false)
  pomodoroAutoFocus  Boolean @default(false)
  pomodoroDailyGoal  Int   @default(8)

  // 日程设置
  weekStart         String   @default("monday") // monday / sunday
  defaultCalendarView String @default("month") // month / week / day
  defaultReminder   Int      @default(15) // 分钟

  // 文献管理设置
  defaultCitationFormat String @default("gb7714")

  // 通知设置
  desktopNotification Boolean @default(true)
  pomodoroSound       Boolean @default(true)
  eventReminder       Boolean @default(true)

  // 数据设置
  autoBackup          Boolean @default(false)
  backupFrequency     String   @default("weekly") // daily / weekly / monthly

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

// ============================================
// 日程模块
// ============================================
model Event {
  id        String    @id @default(cuid())
  userId    String
  title     String
  startAt   DateTime  @db.Timestamptz(3)
  endAt     DateTime  @db.Timestamptz(3)
  timezone  String    @default("Asia/Shanghai")
  rrule     String?   // iCalendar RRULE 格式重复规则
  isAllDay  Boolean   @default(false)
  location  String?
  description String?
  color     String?   // 事件颜色标签
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // 软删除

  // 关联
  user User @relation(fields: [userId], references: [id])

  @@index([userId, startAt])
  @@index([deletedAt])
  @@map("events")
}

// ============================================
// 任务模块（GTD 三级结构）
// ============================================
model Task {
  id            String     @id @default(cuid())
  userId        String
  title         String
  status        TaskStatus @default(TODO)
  priority      Int        @default(4) // P1=1, P2=2, P3=3, P4=4
  sortOrder     Float      @default(0) // 浮点数拖拽排序
  parentId      String?    // 自引用：子任务
  pomodoroCount Int        @default(0) // 已完成番茄数
  dueDate       DateTime?  @db.Timestamptz(3)
  energyLevel   Int?       // 1-5 能量等级
  estimatedMinutes Int?    // 预计耗时（分钟）
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?  // 软删除

  // 关联
  user User  @relation(fields: [userId], references: [id])
  self Task? @relation("TaskParent", fields: [parentId], references: [id])
  children Task[] @relation("TaskParent")
  pomodoroSessions PomodoroSession[]
  referenceId String?
  reference Reference? @relation(fields: [referenceId], references: [id])

  @@index([userId, status])
  @@index([userId, sortOrder])
  @@index([deletedAt])
  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

// ============================================
// 番茄钟模块（行为数据传感器）
// ============================================
model PomodoroSession {
  id                String    @id @default(cuid())
  userId            String
  taskId            String?   // 关联任务（可选）
  duration          Int       // 实际专注秒数
  plannedDuration   Int       // 计划时长（默认 1500 = 25min）
  interruptions     Int       @default(0) // 中断次数
  interruptionType  String?   // JSON 数组：[{"type":"INTERNAL","reason":"..."}, ...]
  startedAt         DateTime  @db.Timestamptz(3)
  endedAt           DateTime? @db.Timestamptz(3)
  notes             String?   // 会话备注
  createdAt         DateTime  @default(now())

  // 关联
  user User  @relation(fields: [userId], references: [id])
  task Task? @relation(fields: [taskId], references: [id])
  referenceId String?
  reference Reference? @relation(fields: [referenceId], references: [id])

  @@index([userId, startedAt])
  @@index([taskId])
  @@index([referenceId])
  @@map("pomodoro_sessions")
}

// ============================================
// 笔记模块（Phase 2）
// ============================================
model Note {
  id         String    @id @default(cuid())
  userId     String
  title      String
  content    Json      // Tiptap JSON 文档结构
  plainText  String    @default("") // 纯文本，用于全文搜索
  summary    String?   // LLM 生成的内容摘要
  tags       String[]  @default([]) // PostgreSQL 文本数组
  folderId   String?   // 所属文件夹（Phase 2 迭代3启用）
  referenceId String?  // 关联文献 ID（Phase 2 阶段2）
  isPinned   Boolean   @default(false)
  isArchived Boolean   @default(false)
  embedding  Unsupported("vector(1024)")? // 预留：语义向量（豆包 Embedding 1024 维）
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime? // 软删除

  // 关联
  user User @relation(fields: [userId], references: [id])
  reference Reference? @relation(fields: [referenceId], references: [id])

  @@index([userId, deletedAt])
  @@index([userId, isPinned, isArchived, updatedAt(sort: Desc)])
  @@index([referenceId])
  @@map("notes")
}

model NoteFolder {
  id        String    @id @default(cuid())
  userId    String
  name      String
  parentId  String?   // 自引用，支持嵌套（Phase 2 迭代3启用）
  sortOrder Float     @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // 关联
  user User @relation(fields: [userId], references: [id])

  @@index([userId, parentId])
  @@map("note_folders")
}

// ============================================
// 文献管理模块（Phase 2）
// ============================================

enum ReadingStatus {
  UNREAD
  READING
  READ
  SKIMMED
  DEEP_READ
}

enum LiteratureType {
  JOURNAL_ARTICLE
  CONFERENCE_PAPER
  PREPRINT
  BOOK
  BOOK_CHAPTER
  THESIS
  REPORT
  PATENT
  OTHER
}

model Reference {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])

  // 核心元数据
  title          String
  authors        String[]       @default([])
  year           Int?
  journal        String?        // 期刊/会议名
  volume         String?
  issue          String?
  pages          String?        // "123-145"
  doi            String?
  arxivId        String?
  pmid           String?
  url            String?        // 论文主页链接
  pdfUrl         String?        // PDF 直链（外部）

  // 内容与摘要
  abstract       String?        @db.Text
  abstractZh     String?        @db.Text // 中文摘要（AI 翻译或手动）
  keywords       String[]       @default([])
  literatureType LiteratureType @default(JOURNAL_ARTICLE)

  // 本地文件
  filePath       String?        // 本地存储的 PDF 路径（相对 uploads/）
  fileSize       Int?           // 字节数
  fileHash       String?        // SHA-256，用于去重
  thumbnailPath  String?        // 缩略图路径

  // 组织与状态
  readingStatus  ReadingStatus  @default(UNREAD)
  priority       Int            @default(3) // 1-4，同 Task
  rating         Int?           // 1-5 星评分
  tags           String[]       @default([])
  folderId       String?
  folder         ReferenceFolder? @relation(fields: [folderId], references: [id])

  // AI 生成内容
  aiSummary      String?        @db.Text // AI 结构化摘要
  keyFindings    String[]       @default([]) // AI 提取的关键发现
  embedding      Unsupported("vector(768)")? // 语义向量

  // 统计
  readCount      Int            @default(0)
  totalReadTime  Int            @default(0) // 总阅读时长（秒）
  lastReadAt     DateTime?      @db.Timestamptz(3)

  // 关联
  notes          ReferenceNote[]
  linkedNotes    Note[]           // 关联的系统笔记（非 PDF 批注）
  tasks          Task[]
  pomodoroSessions PomodoroSession[]

  // 标准字段
  createdAt      DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime       @updatedAt @db.Timestamptz(3)
  deletedAt      DateTime?      @db.Timestamptz(3)

  @@unique([userId, doi])
  @@index([userId, readingStatus])
  @@index([userId, priority])
  @@index([userId, year])
  @@index([userId, folderId])
  @@index([userId, tags])
  @@index([fileHash])
  @@index([deletedAt])
  @@index([userId, createdAt])
  @@map("references")
}

model ReferenceFolder {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  name       String
  parentId   String?
  parent     ReferenceFolder? @relation("RefFolderHierarchy", fields: [parentId], references: [id])
  children   ReferenceFolder[] @relation("RefFolderHierarchy")
  references Reference[]
  sortOrder  Float       @default(0)
  createdAt  DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(3)
  deletedAt  DateTime?   @db.Timestamptz(3)

  @@index([userId, parentId])
  @@index([deletedAt])
  @@map("reference_folders")
}

model ReferenceNote {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  referenceId String
  reference   Reference @relation(fields: [referenceId], references: [id])

  // 批注位置（PDF.js 坐标系）
  pageNumber  Int
  rect        Json?     // { x, y, width, height } 高亮区域
  text        String?   // 选中的原文
  color       String    @default("#FFD700") // 高亮颜色

  // 笔记内容
  content     String    @db.Text
  noteId      String?   // 可选：关联到 Note 系统的笔记

  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  deletedAt   DateTime? @db.Timestamptz(3)

  @@index([referenceId, pageNumber])
  @@index([deletedAt])
  @@map("reference_notes")
}

// ============================================
// AI 对话模块（Phase 3）
// ============================================

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model AiConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  messages AiMessage[]
  user     User     @relation(fields: [userId], references: [id])

  @@index([userId, updatedAt(sort: Desc)])
  @@map("ai_conversations")
}

model AiMessage {
  id             String        @id @default(cuid())
  conversationId String
  role           AiMessageRole
  content        String        @db.Text
  toolCalls      Json?
  createdAt      DateTime      @default(now()) @db.Timestamptz(3)

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}
