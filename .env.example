# ============================================
# PhD_OS 环境变量模板
# 复制为 .env 后修改，.env 已加入 .gitignore
# ============================================

# 数据库
DATABASE_URL="postgresql://phd:phd_dev@localhost:5433/phd_os?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# AI / LLM 配置
# 提供商: kimi-coding | openai | deepseek | moonshot
AI_PROVIDER=kimi-coding
KIMI_CODING_API_KEY="sk-..."
KIMI_CODING_BASE_URL="https://api.kimi.com/coding"
KIMI_CODING_MODEL="k2p5"

# 备选提供商（OpenAI 兼容格式）
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# 服务端口号
BACKEND_PORT=3000
FRONTEND_PORT=5173

# 文件上传
UPLOAD_DIR="./uploads"
